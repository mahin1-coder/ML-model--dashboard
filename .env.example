# Environment Configuration
# Copy this file to .env and update values

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=ml_password_change_me
POSTGRES_DB=ml_dashboard

# Full database URL (update password)
DATABASE_URL=postgresql+asyncpg://ml_user:ml_password_change_me@localhost:5432/ml_dashboard

# ============================================
# Redis Configuration
# ============================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ============================================
# Authentication
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# File Storage
# ============================================
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100

# S3 Configuration (optional)
# S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# ============================================
# Stripe Billing
# ============================================
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_ENTERPRISE=price_your_enterprise_price_id

# ============================================
# Application Settings
# ============================================
APP_NAME=ML Dashboard
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:80

# ============================================
# Email Configuration (optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=noreply@yourdomain.com
